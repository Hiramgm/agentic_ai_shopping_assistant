################################
# APP
################################

APP_NAME=Agentic Shopping Assistant
ENV=dev

################################
# LLM
################################

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

################################
# EMBEDDINGS
################################

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

################################
# VECTOR DB
################################

VECTOR_DB=pinecone

################################
# SEARCH
################################

SEARCH_ENGINE=elasticsearch

################################
# GRAPH DB
################################

GRAPH_DB=neo4j

################################
# CACHE
################################

CACHE_PROVIDER=redis